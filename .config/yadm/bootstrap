#!/bin/bash

# YADM Bootstrap — idempotent, non-interactive
#
# Prerequisites (run these first):
#   yadm clone <repo>
#   yadm decrypt
#
# Then run: yadm bootstrap
# Safe to re-run at any time — each step skips if already done.

set -u  # Treat unset variables as an error

# Setup logging
log_file="$HOME/.yadm_bootstrap.log"
mkdir -p "$(dirname "$log_file")"
exec > >(tee -a "$log_file") 2>&1
echo "=== YADM Bootstrap started at $(date) ==="

# ==============================================================================
# DETECT ENVIRONMENT
# ==============================================================================

export YADM_OS="$(uname)"
echo "OS: $YADM_OS"

export YADM_DISTRO="unknown"
if [[ "$YADM_OS" == "Linux" ]] && [[ -f /etc/os-release ]]; then
    YADM_DISTRO=$(grep ^ID= /etc/os-release | cut -d= -f2 | tr -d '"')
    echo "Distro: $YADM_DISTRO"
fi

detect_gui() {
    if [[ "$YADM_OS" == "Darwin" ]]; then
        echo "true"
        return
    fi
    if [[ -f "$HOME/.config/yadm/flags/has-gui" ]]; then
        echo "true"
        return
    fi
    if [[ -n "${DISPLAY:-}" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "true"
        return
    fi
    if [[ -n "${XDG_SESSION_TYPE:-}" && "${XDG_SESSION_TYPE}" != "tty" ]]; then
        echo "true"
        return
    fi
    if command -v Xorg &>/dev/null || command -v sway &>/dev/null || command -v gnome-session &>/dev/null; then
        echo "true"
        return
    fi
    echo "false"
}

export YADM_HAS_GUI="$(detect_gui)"
echo "GUI: $YADM_HAS_GUI"

# ==============================================================================
# CHECK PREREQUISITES
# ==============================================================================

# Warn if SSH keys aren't set up (but don't block — HTTPS still works)
if [[ -f "$HOME/.ssh/id_rsa" ]]; then
    echo "SSH key: found"
else
    echo ""
    echo "WARNING: No SSH key found at ~/.ssh/id_rsa"
    echo "Some git clones may fail. Run 'yadm decrypt' first if you haven't."
    echo "Continuing anyway..."
    echo ""
fi

# Ensure HTTPS works even if gitconfig rewrites to SSH
# (temporarily disable the rewrite if SSH isn't working)
YADM_RESTORED_HTTPS=false
if git config --global url.git@github.com:.insteadOf &>/dev/null; then
    if ! ssh -T git@github.com -o BatchMode=yes -o ConnectTimeout=5 2>&1 | grep -q "successfully authenticated"; then
        echo "SSH to GitHub not working — temporarily using HTTPS for git clones"
        git config --global --unset url.git@github.com:.insteadOf
        YADM_RESTORED_HTTPS=true
    fi
fi

# ==============================================================================
# STEP 1: OS packages
# ==============================================================================

BOOTSTRAP_DIR="$HOME/.config/yadm/bootstrap.d"

if [[ "$YADM_OS" == "Darwin" ]]; then
    if [[ -f "$BOOTSTRAP_DIR/10-darwin.sh" ]]; then
        echo ""
        source "$BOOTSTRAP_DIR/10-darwin.sh"
    fi
elif [[ "$YADM_OS" == "Linux" ]]; then
    if [[ -f "$BOOTSTRAP_DIR/20-linux.sh" ]]; then
        echo ""
        source "$BOOTSTRAP_DIR/20-linux.sh"
    fi
fi

# ==============================================================================
# STEP 2: Cross-platform tools (mise, TPM, etc.)
# ==============================================================================

if [[ -f "$BOOTSTRAP_DIR/00-common.sh" ]]; then
    echo ""
    source "$BOOTSTRAP_DIR/00-common.sh"
fi

# ==============================================================================
# RESTORE SSH GIT REWRITE
# ==============================================================================

if [[ "$YADM_RESTORED_HTTPS" == "true" ]]; then
    # Check again — maybe SSH keys were already there and it was a transient issue
    if ssh -T git@github.com -o BatchMode=yes -o ConnectTimeout=5 2>&1 | grep -q "successfully authenticated"; then
        echo "Restoring SSH git rewrite..."
        git config --global url.git@github.com:.insteadOf https://github.com/
    else
        echo ""
        echo "NOTE: Git is still using HTTPS (SSH not working)."
        echo "After running 'yadm decrypt', restore SSH with:"
        echo "  git config --global url.git@github.com:.insteadOf https://github.com/"
    fi
fi

echo ""
echo "=== YADM Bootstrap completed at $(date) ==="
